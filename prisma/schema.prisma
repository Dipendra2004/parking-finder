generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  bookmarks Bookmark[]
  reviews   Review[]
  bookings  Booking[]
}

model ParkingSpot {
  id             String     @id @default(uuid())
  name           String
  address        String
  latitude       Float
  longitude      Float
  type           SpotType   @default(OPEN)
  status         SpotStatus @default(AVAILABLE)
  pricePerHour   Float?
  isFree         Boolean    @default(false)
  totalSlots     Int
  hasEVCharging  Boolean    @default(false)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())

  availability Availability?
  reviews      Review[]
  bookmarks    Bookmark[]
  bookings     Booking[]
}

model Availability {
  id             String      @id @default(uuid())
  spotId         String      @unique
  availableSlots Int
  updatedAt      DateTime    @updatedAt

  spot ParkingSpot @relation(fields: [spotId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  userId String
  spotId String
  user   User        @relation(fields: [userId], references: [id])
  spot   ParkingSpot @relation(fields: [spotId], references: [id])
}

model Bookmark {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  spotId String
  user   User        @relation(fields: [userId], references: [id])
  spot   ParkingSpot @relation(fields: [spotId], references: [id])

  @@unique([userId, spotId])
}

enum Role {
  USER
  ADMIN
  OWNER
}

enum SpotType {
  OPEN
  COVERED
  UNDERGROUND
  MULTI_STOREY
}

enum SpotStatus {
  AVAILABLE
  FULL
  CLOSED
}
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Booking {
  id          String        @id @default(uuid())
  userId      String
  spotId      String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?          // Duration in hours
  totalPrice  Float?
  status      BookingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot        ParkingSpot   @relation(fields: [spotId], references: [id], onDelete: Cascade)
}

enum BookingStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}